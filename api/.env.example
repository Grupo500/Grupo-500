# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# NextAuth (mismo secret que el frontend)
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Cloudinary
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# URL pública de esta API (Railway la inyecta como RAILWAY_PUBLIC_DOMAIN automáticamente)
# Solo necesitas definir API_URL si el dominio no se detecta solo
# API_URL=https://api-production-79572.up.railway.app

# Typeform
TYPEFORM_API_KEY=...

# Twilio WhatsApp (futuro)
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Logging
LOG_LEVEL=info

# Encryption (para datos sensibles)
ENCRYPTION_KEY=una-clave-de-32-chars-minimo-aqui
