generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooler — para queries en runtime
  directUrl = env("DIRECT_URL")         // conexión directa — para prisma migrate
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  VENDEDOR
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

enum MetodoPago {
  TRANSFERENCIA
  TARJETA
  EFECTIVO
  OTRO
}

enum EstadoFinanciamiento {
  ACTIVO
  COMPLETADO
  CANCELADO
}

enum TipoCertificado {
  CURSANDO
  COMPLETADO
}

enum RendimientoEstudiante {
  BAJO
  MEDIO
  ALTO
}

enum CalendarioCurso {
  A
  B
}

// ─────────────────────────────────────────────
// Auth & Usuarios
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  hashedPassword String?
  nombre         String?
  imageUrl       String?
  role           Role      @default(VENDEDOR)
  asesor         Asesor?
  accounts       Account[]
  sessions       Session[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// NextAuth — OAuth accounts vinculados al usuario
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

// NextAuth — Sesiones activas
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth — Tokens de verificación de email
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Asesores (Vendedores)
// ─────────────────────────────────────────────

model Asesor {
  id          String      @id @default(cuid())
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String      @unique
  nombre      String
  email       String
  telefono    String
  pagos          Pago[]
  estudiantes    Estudiante[]
  negociaciones  Negociacion[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

// ─────────────────────────────────────────────
// Colegios
// ─────────────────────────────────────────────

model Colegio {
  id               String        @id @default(cuid())
  nombre           String        @unique
  ciudad           String
  contactoNombre   String?
  contactoEmail    String?
  contactoTelefono String?
  estudiantes      Estudiante[]
  negociaciones    Negociacion[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

// ─────────────────────────────────────────────
// Estudiantes
// ─────────────────────────────────────────────

model Estudiante {
  id               String                @id @default(cuid())
  nombre           String
  tipoDocumento    String?               @default("TI")
  documento        String?
  email            String
  telefono         String
  fechaNacimiento  DateTime
  departamento     String?
  ciudad           String?
  direccion        String?
  grado            String?               // 10°, 11°, Egresado
  primerIcfes      Boolean?              @default(true)
  puntajeAnterior  String?
  carreraInteres   String?
  universidadInteres String?
  interesPremedico String?
  colegio          Colegio?              @relation(fields: [colegioId], references: [id])
  colegioId        String?
  asesor           Asesor?               @relation(fields: [asesorId], references: [id])
  asesorId         String?
  acudiente        Acudiente?
  cursos           CursoEstudiante[]
  pagos            Pago[]
  financiamientos  Financiamiento[]
  simulacros       SimulacroEstudiante[]
  certificados     Certificado[]
  historial        HistorialEstudiante[]
  fuenteContacto   FuenteContacto?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
}

// ─────────────────────────────────────────────
// Historial de cambios por estudiante
// ─────────────────────────────────────────────

model HistorialEstudiante {
  id           String     @id @default(cuid())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId String
  accion       String     // UPDATE_PERFIL, PAGO_CUOTA, ABONO, CREAR_FINANCIAMIENTO, etc.
  descripcion  String
  cambios      Json?
  realizadoPor String
  userId       String
  createdAt    DateTime   @default(now())
}

model Acudiente {
  id              String     @id @default(cuid())
  nombre          String
  email           String?
  telefono        String
  relacion        String
  tipoDocumento   String?
  numeroDocumento String?
  estudiante      Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId    String     @unique
}

// ─────────────────────────────────────────────
// Marketing — fuente de contacto por estudiante
// ─────────────────────────────────────────────

model FuenteContacto {
  id           String     @id @default(cuid())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId String     @unique
  fuente       String     // Instagram, TikTok, Facebook, YouTube, Google, Referido, etc.
  formId       String?    // ID del formulario Typeform
  respondedAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
}

// ─────────────────────────────────────────────
// Cursos
// ─────────────────────────────────────────────

model Curso {
  id            String            @id @default(cuid())
  nombre        String
  descripcion   String?
  precio        Float
  duracionHoras Int
  calendario    CalendarioCurso   @default(A)
  fechaInicio   DateTime?
  fechaFin      DateTime?
  activo        Boolean           @default(true)
  estudiantes   CursoEstudiante[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CursoEstudiante {
  id                  String     @id @default(cuid())
  estudiante          Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId        String
  curso               Curso      @relation(fields: [cursoId], references: [id])
  cursoId             String
  descuentoPorcentaje Float      @default(0)
  fechaCompra         DateTime   @default(now())

  @@unique([estudianteId, cursoId])
}

// ─────────────────────────────────────────────
// Pagos
// ─────────────────────────────────────────────

model Pago {
  id               String     @id @default(cuid())
  estudiante       Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId     String
  asesor           Asesor?    @relation(fields: [asesorId], references: [id])
  asesorId         String?
  monto            Float
  estado           EstadoPago @default(PENDIENTE)
  metodo           MetodoPago
  fechaVencimiento DateTime
  fechaPago        DateTime?
  comprobante      String?    // URL en Cloudinary
  notas            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

// ─────────────────────────────────────────────
// Financiamientos & Cuotas
// ─────────────────────────────────────────────

model Financiamiento {
  id           String               @id @default(cuid())
  estudiante   Estudiante           @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId String
  montoTotal   Float
  estado       EstadoFinanciamiento @default(ACTIVO)
  cuotas       Cuota[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Cuota {
  id               String         @id @default(cuid())
  financiamiento   Financiamiento @relation(fields: [financiamientoId], references: [id], onDelete: Cascade)
  financiamientoId String
  numero           Int
  monto            Float
  fechaVencimiento DateTime
  pagado           Boolean        @default(false)
  fechaPago        DateTime?
  comprobante      String?
  medioPago        String?
  notas            String?
  reminders        ReminderCobro[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// ─────────────────────────────────────────────
// Cobros & Reminders WhatsApp
// ─────────────────────────────────────────────

model ReminderCobro {
  id               String   @id @default(cuid())
  cuota            Cuota    @relation(fields: [cuotaId], references: [id], onDelete: Cascade)
  cuotaId          String
  fechaProgramada  DateTime
  enviado          Boolean  @default(false)
  fechaEnvio       DateTime?
  numeroIntento    Int      @default(0)
  mensajeEnviado   String?
  createdAt        DateTime @default(now())
}

// ─────────────────────────────────────────────
// Certificados
// ─────────────────────────────────────────────

model Certificado {
  id           String          @id @default(cuid())
  estudiante   Estudiante      @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId String
  tipo         TipoCertificado
  archivoUrl   String          // URL PDF en Cloudinary
  numeroSerie  String          @unique
  fechaEmision DateTime        @default(now())
  expiracion   DateTime?
}

// ─────────────────────────────────────────────
// Simulacros & Análisis
// ─────────────────────────────────────────────

model Simulacro {
  id            String                @id @default(cuid())
  nombre        String
  archivoUrl    String                // URL PDF en Cloudinary
  procesado     Boolean               @default(false)
  estudiantes   SimulacroEstudiante[]
  createdAt     DateTime              @default(now())
}

model SimulacroEstudiante {
  id                  String                @id @default(cuid())
  estudiante          Estudiante            @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  estudianteId        String
  simulacro           Simulacro             @relation(fields: [simulacroId], references: [id], onDelete: Cascade)
  simulacroId         String
  puntajeTotal        Int
  porcentajeAciertos  Float
  areasDebiles        String[]
  rendimiento         RendimientoEstudiante
  requiereIntensivo   Boolean               @default(false)
  fechaAnalisis       DateTime              @default(now())

  @@unique([estudianteId, simulacroId])
}


model ConfigApp {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

enum EtapaNegociacion {
  PROSPECTO
  CONTACTO
  PROPUESTA
  REUNION
  CONVENIO
  DESCARTADO
}

model Negociacion {
  id          String             @id @default(cuid())
  colegio     Colegio            @relation(fields: [colegioId], references: [id], onDelete: Cascade)
  colegioId   String
  asesor      Asesor             @relation(fields: [asesorId], references: [id])
  asesorId    String
  etapa       EtapaNegociacion   @default(PROSPECTO)
  notas       String?
  fechaContacto   DateTime?
  fechaReunion    DateTime?
  fechaProxContacto DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}
