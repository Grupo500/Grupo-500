generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  role           Role      @default(VENDEDOR)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  image          String?
  nombre         String?
  emailVerified  DateTime?
  hashedPassword String?
  accounts       Account[]
  asesor         Asesor?
  passkeys       Passkey[]
  sessions       Session[]
  pushSubs       PushSubscription[]
  apiKeys        ApiKey[]
}

model ApiKey {
  id          String    @id @default(cuid())
  nombre      String
  keyHash     String    @unique
  prefijo     String
  scopes      String[]
  activa      Boolean   @default(true)
  ultimoUso   DateTime?
  creadaPorId String
  creadaPor   User      @relation(fields: [creadaPorId], references: [id])
  createdAt   DateTime  @default(now())
  revocadaAt  DateTime?
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String
  backedUp     Boolean   @default(false)
  transports   String[]
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Asesor {
  id            String        @id @default(cuid())
  userId        String        @unique
  nombre        String
  email         String
  // Correo alterno de solo lectura para cruzar leads de Trengo/HubSpot cuando
  // el asesor inició sesión ahí con un correo distinto al de su perfil (ej.
  // Sara Duarte: perfil saraduarte5500@gmail.com, Trengo funnyplayer407@gmail.com).
  // Campo interno — no se expone en ningún formulario, se asigna a mano por caso.
  emailCrm      String?
  telefono      String
  // Códigos de rastreo Hotmart (src/sck de sus links) + email de afiliado
  codigosHotmart String[]     @default([])
  // Snapshot del ranking para detectar rebases entre ventas (notificaciones push)
  posicionRanking Int?
  posicionMes    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  estudiantes   Estudiante[]
  negociaciones Negociacion[]
  pagos         Pago[]
}

model Colegio {
  id               String        @id @default(cuid())
  nombre           String        @unique
  ciudad           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contactoNombre   String?
  contactoEmail    String?
  contactoTelefono String?
  estudiantes      Estudiante[]
  negociaciones    Negociacion[]
  estudiantesExamen EstudianteExamen[]
}

model Estudiante {
  id                 String                @id @default(cuid())
  nombre             String
  email              String
  telefono           String
  fechaNacimiento    DateTime
  colegioId          String?
  asesorId           String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  ciudad             String?
  departamento       String?
  documento          String?
  tipoDocumento      String?               @default("TI")
  carreraInteres     String?
  grado              String?
  interesPremedico   String?
  primerIcfes        Boolean?              @default(true)
  puntajeAnterior    String?
  universidadInteres String?
  lineaAutorizada    Int?
  agregado           Boolean               @default(false)
  nombreGrupo        String?
  documentoUrl       String?
  direccion          String?
  verificado         Boolean               @default(false)
  verificadoPor      String?
  verificadoAt       DateTime?
  acudiente          Acudiente?
  certificados       Certificado[]
  cursos             CursoEstudiante[]
  asesor             Asesor?               @relation(fields: [asesorId], references: [id])
  colegio            Colegio?              @relation(fields: [colegioId], references: [id])
  fuenteContacto     FuenteContacto?
  historial          HistorialEstudiante[]
  observaciones      Observacion[]
  pagos              Pago[]
  simulacros         SimulacroEstudiante[]
}

model HistorialEstudiante {
  id           String     @id @default(cuid())
  estudianteId String
  accion       String
  descripcion  String
  cambios      Json?
  realizadoPor String
  userId       String
  createdAt    DateTime   @default(now())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Observacion {
  id           String     @id @default(cuid())
  estudianteId String
  texto        String
  autor        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Acudiente {
  id              String     @id @default(cuid())
  nombre          String
  email           String?
  telefono        String
  relacion        String
  estudianteId    String     @unique
  numeroDocumento String?
  tipoDocumento   String?
  estudiante      Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model FuenteContacto {
  id           String     @id @default(cuid())
  estudianteId String     @unique
  fuente       String
  formId       String?
  respondedAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Curso {
  id                String            @id @default(cuid())
  nombre            String
  descripcion       String?
  precio            Float
  duracionHoras     Int
  activo            Boolean           @default(true)
  tipoCurso         TipoCurso         @default(INDIVIDUAL)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  calendario        CalendarioCurso   @default(A)
  fechaFin          DateTime?
  fechaInicio       DateTime?
  fechaIcfes        DateTime?
  simulacros        Int?
  visibleEnLanding  Boolean           @default(false)
  cuposDisponibles  Int?
  hotmartProductId  String?           @unique
  estudiantes       CursoEstudiante[]
}

model Formulario {
  id               String    @id @default(cuid())
  nombre           String
  descripcion      String?
  campos           Json      // FieldSchema[]
  meta             Json?     // { colorPrimario, mensajeBienvenida, mensajeExito, icono }
  activo           Boolean   @default(false)
  visibleEnLanding Boolean   @default(false)
  cursoId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CursoEstudiante {
  id                  String     @id @default(cuid())
  estudianteId        String
  cursoId             String
  fechaCompra         DateTime   @default(now())
  descuentoPorcentaje Float      @default(0)
  // Total real acordado con este estudiante (precio Hotmart con descuento).
  // Si es null, se usa el precio de lista del curso.
  precioAcordado      Float?
  curso               Curso      @relation(fields: [cursoId], references: [id])
  estudiante          Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, cursoId])
}

model Pago {
  id               String     @id @default(cuid())
  estudianteId     String
  asesorId         String?
  monto            Float
  estado           EstadoPago @default(PENDIENTE)
  metodo           String
  fechaVencimiento DateTime
  fechaPago        DateTime?
  comprobante      String?
  referenciaPago   String?
  comprobanteAt    DateTime?
  notas            String?
  // Desglose de comisiones (en COP, convertido desde USD con TRM oficial de la fecha)
  comisionHotmart  Float?     // comisión de la plataforma Hotmart (fee + addon)
  comisionAsesor   Float?     // comisión del afiliado/asesor
  montoNeto        Float?     // neto que recibe el productor
  trm              Float?     // TRM oficial usada para la conversión
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  asesor           Asesor?    @relation(fields: [asesorId], references: [id])
  estudiante       Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Certificado {
  id           String          @id @default(cuid())
  estudianteId String
  tipo         TipoCertificado
  archivoUrl   String
  numeroSerie  String          @unique
  fechaEmision DateTime        @default(now())
  expiracion   DateTime?
  estudiante   Estudiante      @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Simulacro {
  id           String                @id @default(cuid())
  nombre       String
  archivoUrl   String
  tipoArchivo  String                @default("pdf")
  procesado    Boolean               @default(false)
  createdAt    DateTime              @default(now())
  estudiantes  SimulacroEstudiante[]
}

model SimulacroEstudiante {
  id                 String                @id @default(cuid())
  estudianteId       String
  simulacroId        String
  puntajeTotal       Int
  porcentajeAciertos Float
  areasDebiles       String[]
  rendimiento        RendimientoEstudiante
  requiereIntensivo  Boolean               @default(false)
  fechaAnalisis      DateTime              @default(now())
  estudiante         Estudiante            @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  simulacro          Simulacro             @relation(fields: [simulacroId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, simulacroId])
}

model ConfigApp {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

model Negociacion {
  id                String           @id @default(cuid())
  colegioId         String
  asesorId          String
  etapa             EtapaNegociacion @default(PROSPECTO)
  notas             String?
  fechaContacto     DateTime?
  fechaReunion      DateTime?
  fechaProxContacto DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  asesor            Asesor           @relation(fields: [asesorId], references: [id])
  colegio           Colegio          @relation(fields: [colegioId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  VENDEDOR
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

enum TipoCertificado {
  CURSANDO
  COMPLETADO
}

enum RendimientoEstudiante {
  BAJO
  MEDIO
  ALTO
}

enum CalendarioCurso {
  A
  B
}

enum TipoCurso {
  INDIVIDUAL
  COMBO
}

enum EtapaNegociacion {
  PROSPECTO
  CONTACTO
  PROPUESTA
  REUNION
  CONVENIO
  DESCARTADO
}

// Conversaciones de Trengo asignadas a un asesor (= leads).
// El webhook upsertea por ticketId; si cambia el asesor se actualiza el agentEmail
// y se preserva firstAssignedAt para distinguir "lead nuevo" de "reasignación".
model TrengoTicket {
  ticketId         String   @id
  agentEmail       String
  firstAssignedAt  DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([agentEmail])
  @@index([firstAssignedAt])
}

// Leads provenientes de HubSpot: cada Ticket (conversación autoasignada a
// un asesor — chat, email, formulario) cuenta como un lead, igual que
// TrengoTicket. Cruzados por el email del "owner" asignado en HubSpot.
model HubspotLead {
  ticketId         String   @id
  ownerEmail       String
  createdAtHubspot DateTime
  updatedAt        DateTime @updatedAt

  @@index([ownerEmail])
  @@index([createdAtHubspot])
}

// ============================================================
// MÓDULO SIMULACROS (motor de examen online)
// Migrado desde la app simulacros-grupo500 (Supabase → Railway PG).
// Tablas conservan nombre sim_* (@@map) para no chocar con el
// modelo `Simulacro` existente (que es análisis de PDFs, otra cosa).
// Estudiantes de examen = tabla aparte (NO el Estudiante de ventas).
// ============================================================

model Examen {
  id          Int              @id // ids explícitos (1,2,3), no autoincrement
  titulo      String
  descripcion String?
  abreAt      DateTime?        @map("abre_at")
  cierraAt    DateTime?        @map("cierra_at")
  duracionMin Int?             @map("duracion_min")
  activo      Boolean          @default(false)
  preguntas   PreguntaExamen[]
  intentos    IntentoExamen[]

  @@map("sim_simulacros")
}

model PreguntaExamen {
  id          BigInt  @id @default(autoincrement())
  examenId    Int     @map("simulacro_id")
  sesion      Int
  area        String?
  numero      Int?
  contexto    String?
  enunciado   String
  opcionA     String? @map("opcion_a")
  opcionB     String? @map("opcion_b")
  opcionC     String? @map("opcion_c")
  opcionD     String? @map("opcion_d")
  opcionE     String? @map("opcion_e")
  opcionF     String? @map("opcion_f")
  opcionG     String? @map("opcion_g")
  opcionH     String? @map("opcion_h")
  correcta      String  @db.Char(1)
  explicacion   String?
  retroOpciones Json?   @map("retro_opciones")
  imagenUrl     String? @map("imagen_url")
  tieneImagen   Boolean @default(false) @map("tiene_imagen")
  examen        Examen  @relation(fields: [examenId], references: [id])
  britoLecciones BritoLeccionPregunta[]

  @@index([examenId, sesion, numero])
  @@map("sim_preguntas")
}

model EstudianteExamen {
  id            String          @id @default(uuid()) @db.Uuid
  email         String          @unique
  documentoHash String          @map("documento_hash")
  nombre        String
  colegioId     String?         @map("colegio_id")
  creadoAt      DateTime        @default(now()) @map("creado_at")
  colegio       Colegio?        @relation(fields: [colegioId], references: [id])
  intentos      IntentoExamen[]
  britoPerfil   BritoPerfil?

  @@map("sim_estudiantes")
}

// ── Brito: modo de práctica gamificado, capa nueva sobre el banco de preguntas
// existente (PreguntaExamen). No toca el motor de simulacros/exámenes real. ──
model BritoLeccion {
  id        String                 @id @default(cuid())
  materia   String
  titulo    String
  orden     Int
  sesion    Int                    @default(1)
  createdAt DateTime               @default(now())
  preguntas BritoLeccionPregunta[]
  completadas BritoLeccionCompletada[]

  @@map("brito_lecciones")
}

model BritoLeccionPregunta {
  leccionId  String
  preguntaId BigInt
  orden      Int
  leccion    BritoLeccion   @relation(fields: [leccionId], references: [id], onDelete: Cascade)
  pregunta   PreguntaExamen @relation(fields: [preguntaId], references: [id])

  @@id([leccionId, preguntaId])
  @@map("brito_leccion_preguntas")
}

model BritoPerfil {
  id              String    @id @default(cuid())
  estudianteId    String    @unique @db.Uuid
  xpTotal         Int       @default(0)
  corazones       Int       @default(5)
  corazonesAt     DateTime  @default(now())
  rachaActual     Int       @default(0)
  rachaMejor      Int       @default(0)
  ultimaLeccionAt DateTime?
  plan            String    @default("FREE")
  createdAt       DateTime  @default(now())
  estudiante      EstudianteExamen @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@map("brito_perfiles")
}

model BritoLeccionCompletada {
  id           String       @id @default(cuid())
  estudianteId String       @db.Uuid
  leccionId    String
  correctas    Int
  total        Int
  xpGanado     Int
  completadaAt DateTime     @default(now())
  leccion      BritoLeccion @relation(fields: [leccionId], references: [id], onDelete: Cascade)

  @@index([estudianteId, leccionId])
  @@map("brito_lecciones_completadas")
}

model IntentoExamen {
  id                  BigInt           @id @default(autoincrement())
  estudianteId        String           @map("estudiante_id") @db.Uuid
  examenId            Int              @map("simulacro_id")
  respuestas          Json             @default("{}")
  correctas           Int?
  total                Int?
  puntaje             Decimal?         @db.Decimal
  sesionActual        Int              @default(1) @map("sesion_actual")
  iniciadoAt          DateTime         @default(now()) @map("iniciado_at")
  finalizadoAt        DateTime?        @map("finalizado_at")
  sesion1IniciadoEn   DateTime?        @map("sesion1_iniciado_en")
  sesion1ConsumidoSeg Int              @default(0) @map("sesion1_consumido_seg")
  sesion2IniciadoEn   DateTime?        @map("sesion2_iniciado_en")
  sesion2ConsumidoSeg Int              @default(0) @map("sesion2_consumido_seg")
  estudiante          EstudianteExamen @relation(fields: [estudianteId], references: [id])
  examen              Examen           @relation(fields: [examenId], references: [id])

  @@unique([estudianteId, examenId])
  @@map("sim_intentos")
}
