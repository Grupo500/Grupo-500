generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  role           Role      @default(VENDEDOR)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  image          String?
  nombre         String?
  emailVerified  DateTime?
  hashedPassword String?
  accounts       Account[]
  asesor         Asesor?
  passkeys       Passkey[]
  sessions       Session[]
}

model Passkey {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    Bytes
  counter      BigInt    @default(0)
  deviceType   String
  backedUp     Boolean   @default(false)
  transports   String[]
  name         String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Asesor {
  id            String        @id @default(cuid())
  userId        String        @unique
  nombre        String
  email         String
  telefono      String
  // Códigos de rastreo Hotmart (src/sck de sus links) + email de afiliado
  codigosHotmart String[]     @default([])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  estudiantes   Estudiante[]
  negociaciones Negociacion[]
  pagos         Pago[]
}

model Colegio {
  id               String        @id @default(cuid())
  nombre           String        @unique
  ciudad           String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contactoNombre   String?
  contactoEmail    String?
  contactoTelefono String?
  estudiantes      Estudiante[]
  negociaciones    Negociacion[]
}

model Estudiante {
  id                 String                @id @default(cuid())
  nombre             String
  email              String
  telefono           String
  fechaNacimiento    DateTime
  colegioId          String?
  asesorId           String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  ciudad             String?
  departamento       String?
  documento          String?
  tipoDocumento      String?               @default("TI")
  carreraInteres     String?
  grado              String?
  interesPremedico   String?
  primerIcfes        Boolean?              @default(true)
  puntajeAnterior    String?
  universidadInteres String?
  lineaAutorizada    Int?
  agregado           Boolean               @default(false)
  nombreGrupo        String?
  documentoUrl       String?
  direccion          String?
  verificado         Boolean               @default(false)
  verificadoPor      String?
  verificadoAt       DateTime?
  acudiente          Acudiente?
  certificados       Certificado[]
  cursos             CursoEstudiante[]
  asesor             Asesor?               @relation(fields: [asesorId], references: [id])
  colegio            Colegio?              @relation(fields: [colegioId], references: [id])
  financiamientos    Financiamiento[]
  fuenteContacto     FuenteContacto?
  historial          HistorialEstudiante[]
  observaciones      Observacion[]
  pagos              Pago[]
  simulacros         SimulacroEstudiante[]
}

model HistorialEstudiante {
  id           String     @id @default(cuid())
  estudianteId String
  accion       String
  descripcion  String
  cambios      Json?
  realizadoPor String
  userId       String
  createdAt    DateTime   @default(now())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Observacion {
  id           String     @id @default(cuid())
  estudianteId String
  texto        String
  autor        String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Acudiente {
  id              String     @id @default(cuid())
  nombre          String
  email           String?
  telefono        String
  relacion        String
  estudianteId    String     @unique
  numeroDocumento String?
  tipoDocumento   String?
  estudiante      Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model FuenteContacto {
  id           String     @id @default(cuid())
  estudianteId String     @unique
  fuente       String
  formId       String?
  respondedAt  DateTime   @default(now())
  createdAt    DateTime   @default(now())
  estudiante   Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Curso {
  id                String            @id @default(cuid())
  nombre            String
  descripcion       String?
  precio            Float
  duracionHoras     Int
  activo            Boolean           @default(true)
  tipoCurso         TipoCurso         @default(INDIVIDUAL)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  calendario        CalendarioCurso   @default(A)
  fechaFin          DateTime?
  fechaInicio       DateTime?
  fechaIcfes        DateTime?
  simulacros        Int?
  visibleEnLanding  Boolean           @default(false)
  cuposDisponibles  Int?
  hotmartProductId  String?           @unique
  estudiantes       CursoEstudiante[]
}

model Formulario {
  id               String    @id @default(cuid())
  nombre           String
  descripcion      String?
  campos           Json      // FieldSchema[]
  meta             Json?     // { colorPrimario, mensajeBienvenida, mensajeExito, icono }
  activo           Boolean   @default(false)
  visibleEnLanding Boolean   @default(false)
  cursoId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model CursoEstudiante {
  id                  String     @id @default(cuid())
  estudianteId        String
  cursoId             String
  fechaCompra         DateTime   @default(now())
  descuentoPorcentaje Float      @default(0)
  curso               Curso      @relation(fields: [cursoId], references: [id])
  estudiante          Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, cursoId])
}

model Pago {
  id               String     @id @default(cuid())
  estudianteId     String
  asesorId         String?
  monto            Float
  estado           EstadoPago @default(PENDIENTE)
  metodo           String
  fechaVencimiento DateTime
  fechaPago        DateTime?
  comprobante      String?
  referenciaPago   String?
  comprobanteAt    DateTime?
  notas            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  asesor           Asesor?    @relation(fields: [asesorId], references: [id])
  estudiante       Estudiante @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Financiamiento {
  id           String               @id @default(cuid())
  estudianteId String
  montoTotal   Float
  estado       EstadoFinanciamiento @default(ACTIVO)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  cuotas       Cuota[]
  estudiante   Estudiante           @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Cuota {
  id               String          @id @default(cuid())
  financiamientoId String
  numero           Int
  monto            Float
  fechaVencimiento DateTime
  pagado           Boolean         @default(false)
  fechaPago        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  comprobante      String?
  medioPago        String?
  notas            String?
  financiamiento   Financiamiento  @relation(fields: [financiamientoId], references: [id], onDelete: Cascade)
  reminders        ReminderCobro[]
}

model ReminderCobro {
  id              String    @id @default(cuid())
  cuotaId         String
  fechaProgramada DateTime
  enviado         Boolean   @default(false)
  fechaEnvio      DateTime?
  numeroIntento   Int       @default(0)
  mensajeEnviado  String?
  createdAt       DateTime  @default(now())
  cuota           Cuota     @relation(fields: [cuotaId], references: [id], onDelete: Cascade)
}

model Certificado {
  id           String          @id @default(cuid())
  estudianteId String
  tipo         TipoCertificado
  archivoUrl   String
  numeroSerie  String          @unique
  fechaEmision DateTime        @default(now())
  expiracion   DateTime?
  estudiante   Estudiante      @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
}

model Simulacro {
  id           String                @id @default(cuid())
  nombre       String
  archivoUrl   String
  tipoArchivo  String                @default("pdf")
  procesado    Boolean               @default(false)
  createdAt    DateTime              @default(now())
  estudiantes  SimulacroEstudiante[]
}

model SimulacroEstudiante {
  id                 String                @id @default(cuid())
  estudianteId       String
  simulacroId        String
  puntajeTotal       Int
  porcentajeAciertos Float
  areasDebiles       String[]
  rendimiento        RendimientoEstudiante
  requiereIntensivo  Boolean               @default(false)
  fechaAnalisis      DateTime              @default(now())
  estudiante         Estudiante            @relation(fields: [estudianteId], references: [id], onDelete: Cascade)
  simulacro          Simulacro             @relation(fields: [simulacroId], references: [id], onDelete: Cascade)

  @@unique([estudianteId, simulacroId])
}

model ConfigApp {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt
}

model Negociacion {
  id                String           @id @default(cuid())
  colegioId         String
  asesorId          String
  etapa             EtapaNegociacion @default(PROSPECTO)
  notas             String?
  fechaContacto     DateTime?
  fechaReunion      DateTime?
  fechaProxContacto DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  asesor            Asesor           @relation(fields: [asesorId], references: [id])
  colegio           Colegio          @relation(fields: [colegioId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  VENDEDOR
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

enum EstadoFinanciamiento {
  ACTIVO
  COMPLETADO
  CANCELADO
}

enum TipoCertificado {
  CURSANDO
  COMPLETADO
}

enum RendimientoEstudiante {
  BAJO
  MEDIO
  ALTO
}

enum CalendarioCurso {
  A
  B
}

enum TipoCurso {
  INDIVIDUAL
  COMBO
}

enum EtapaNegociacion {
  PROSPECTO
  CONTACTO
  PROPUESTA
  REUNION
  CONVENIO
  DESCARTADO
}
